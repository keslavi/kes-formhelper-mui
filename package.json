{
  "name": "kes-formhelper-mui",
  "version": "0.1.4",
  "description": "Form helper components for MUI built on react-hook-form.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keslavi/kes-formhelper-mui.git"
  },
  "bugs": {
    "url": "https://github.com/keslavi/kes-formhelper-mui/issues"
  },
  "homepage": "https://github.com/keslavi/kes-formhelper-mui#readme",
  "type": "module",
  "main": "dist/formhelper-mui.cjs",
  "module": "dist/formhelper-mui.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/formhelper-mui.js",
      "require": "./dist/formhelper-mui.cjs"
    },
    "./storybook-embed": {
      "types": "./dist/storybook-embed.d.ts",
      "import": "./dist/storybook-embed.js",
      "require": "./dist/storybook-embed.cjs"
    }
  },
  "files": [
    "dist",
    "storybook-static",
    "src/stories"
  ],
  "keywords": [
    "react",
    "mui",
    "form",
    "react-hook-form",
    "components"
  ],
  "scripts": {
    "start": "node ./scripts/start.mjs",
    "dev": "vite",
    "build": "npm run build:lib && npm run storybook-build",
    "build:lib": "tsc -p tsconfig.app.json --noEmit && vite build",
    "deploy:seed": "npm run build && node ./scripts/formhelper-deploy.js",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "node scripts/kill-dev-ports.mjs 5200 && storybook dev -p 5200 --exact-port --host 127.0.0.1",
    "storybook-build": "storybook build",
    "storybook-deploy": "npm run storybook-build && node ./scripts/storybook-deploy.js",
    "prepublishOnly": "npm run build",
    "test": "node scripts/kill-dev-ports.mjs 5300 && vitest --ui --watch --project=unit --api.port 5300",
    "test-once": "node scripts/kill-dev-ports.mjs 5300 && vitest run --project=unit"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "react": ">=18",
    "react-dom": ">=18",
    "react-hook-form": ">=7"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^9.39.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.52.2",
    "storybook": "^10.4.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.10",
    "yup": "^1.7.1"
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "lodash": "^4.17.23"
  }
}
